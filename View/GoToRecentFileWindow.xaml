<Window x:Class="GoToRecentFile.View.GoToRecentFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:GoToRecentFile.View"
        xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
        mc:Ignorable="d"
        Title="Go To Recent File"
        Icon="/GoToRecentFile;component/Resources/Icon.png"
        MinWidth="760"
        MinHeight="420"
        Width="980"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontSize="12"
        Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
        Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}">
    <Window.Resources>
        <local:HighlightConverter x:Key="HighlightConverter" HighlightBrush="Yellow"/>

        <!-- Gradient light gray for selected items in light theme -->
        <LinearGradientBrush x:Key="SelectedItemGradientLight" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFF0F0F0" Offset="0"/>
            <GradientStop Color="#FFE0E0E0" Offset="0.5"/>
            <GradientStop Color="#FFD0D0D0" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SelectedItemBorderLight" Color="DarkGray"/>

        <!-- Gradient gray for selected items in dark theme -->
        <LinearGradientBrush x:Key="SelectedItemGradientDark" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF585858" Offset="0"/>
            <GradientStop Color="#FF484848" Offset="0.5"/>
            <GradientStop Color="#FF3A3A3A" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SelectedItemBorderDark" Color="DarkGray"/>

        <!-- Active brushes (swapped at runtime based on theme) -->
        <LinearGradientBrush x:Key="SelectedItemBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFF0F0F0" Offset="0"/>
            <GradientStop Color="#FFE0E0E0" Offset="0.5"/>
            <GradientStop Color="#FFD0D0D0" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SelectedItemBorder" Color="DarkGray"/>
        <SolidColorBrush x:Key="SelectedItemForeground" Color="#FF000000"/>

        <!-- Column header hover/pressed brushes (swapped at runtime based on theme) -->
        <SolidColorBrush x:Key="ColumnHeaderHoverBg" Color="#FFE8E8E8"/>
        <SolidColorBrush x:Key="ColumnHeaderHoverBorder" Color="DarkGray"/>
        <SolidColorBrush x:Key="ColumnHeaderPressedBg" Color="#FFD0D0D0"/>
        <SolidColorBrush x:Key="ColumnHeaderPressedBorder" Color="Gray"/>

        <!-- Sort arrow header templates -->
        <DataTemplate x:Key="HeaderTemplateArrowUp">
            <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">
                <Path DockPanel.Dock="Right" Margin="4,0,0,0"
                      StrokeThickness="1"
                      Fill="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                      Data="M 0,6 L 4,0 L 8,6 Z"
                      VerticalAlignment="Center"/>
                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </DockPanel>
        </DataTemplate>
        <DataTemplate x:Key="HeaderTemplateArrowDown">
            <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">
                <Path DockPanel.Dock="Right" Margin="4,0,0,0"
                      StrokeThickness="1"
                      Fill="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                      Data="M 0,0 L 4,6 L 8,0 Z"
                      VerticalAlignment="Center"/>
                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </DockPanel>
        </DataTemplate>

        <!-- Left-align column headers with subtle VS-themed hover -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="6,3,6,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border x:Name="HeaderBorder"
                                    BorderThickness="0,0,1,1"
                                    BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter x:Name="HeaderContent"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <!-- PART_HeaderGripper is required by GridViewColumnHeader for column resize -->
                            <Thumb x:Name="PART_HeaderGripper"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,-9,0"
                                   Width="18"
                                   Cursor="SizeWE">
                                <Thumb.Style>
                                    <Style TargetType="Thumb">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="Transparent"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Thumb.Style>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background"
                                        Value="{DynamicResource ColumnHeaderHoverBg}"/>
                                <Setter TargetName="HeaderBorder" Property="BorderBrush"
                                        Value="{DynamicResource ColumnHeaderHoverBorder}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background"
                                        Value="{DynamicResource ColumnHeaderPressedBg}"/>
                                <Setter TargetName="HeaderBorder" Property="BorderBrush"
                                        Value="{DynamicResource ColumnHeaderPressedBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView item style: themed selection, outline on hover, close button -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="21"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                    <Grid SnapsToDevicePixels="True" UseLayoutRounding="True" Background="Transparent">
                        <!-- Background layer for selection fill -->
                        <Border x:Name="BgBd" Background="Transparent"/>
                        <!-- Content layer with cell borders for vertical lines -->
                        <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        <!-- Overlay border for hover/selection outline (does not affect layout) -->
                        <Border x:Name="OutlineBd"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                IsHitTestVisible="False"/>
                            <!-- Close button -->
                            <Button x:Name="CloseBtn"
                                    Visibility="Hidden"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Width="16" Height="16"
                                    Margin="0,0,4,0"
                                    Cursor="Hand"
                                    Click="CloseFileButton_Click"
                                    ToolTip="Remove from Recent Files List"
                                    Tag="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid Width="16" Height="16" SnapsToDevicePixels="True">
                                            <Border x:Name="InactiveBd"
                                                    Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
                                                    BorderBrush="#FFE04040" BorderThickness="1"
                                                    CornerRadius="1">
                                                <Canvas Width="10" Height="10"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <Line X1="0" Y1="0" X2="10" Y2="10" Stroke="#FFE04040" StrokeThickness="1.5"/>
                                                    <Line X1="10" Y1="0" X2="0" Y2="10" Stroke="#FFE04040" StrokeThickness="1.5"/>
                                                </Canvas>
                                            </Border>
                                            <Border x:Name="ActiveBd" Background="#FFE04040"
                                                    BorderBrush="#FFE04040" BorderThickness="1"
                                                    CornerRadius="1" Visibility="Collapsed">
                                                <Canvas Width="10" Height="10"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <Line X1="0" Y1="0" X2="10" Y2="10" Stroke="White" StrokeThickness="1.5"/>
                                                    <Line X1="10" Y1="0" X2="0" Y2="10" Stroke="White" StrokeThickness="1.5"/>
                                                </Canvas>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="InactiveBd" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="ActiveBd" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="InactiveBd" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="ActiveBd" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="ActiveBd" Property="Background" Value="#FFC03030"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Hover: hollow outline only, no fill -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OutlineBd" Property="BorderBrush"
                                        Value="DarkGray"/>
                                <Setter TargetName="CloseBtn" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <!-- Selected: themed gradient fill -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BgBd" Property="Background"
                                        Value="{DynamicResource SelectedItemBrush}"/>
                                <Setter TargetName="OutlineBd" Property="BorderBrush"
                                        Value="{DynamicResource SelectedItemBorder}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SelectedItemForeground}"/>
                            </Trigger>
                            <!-- Selected + Hover: keep gradient selection, show close button -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="BgBd" Property="Background"
                                        Value="{DynamicResource SelectedItemBrush}"/>
                                <Setter TargetName="OutlineBd" Property="BorderBrush"
                                        Value="{DynamicResource SelectedItemBorder}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SelectedItemForeground}"/>
                                <Setter TargetName="CloseBtn" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView style with gray border -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Style for SearchBox TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
        </Style>

        <!-- Style for Buttons -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ButtonFaceKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ButtonTextKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ButtonShadowKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedBorderKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseDownBackgroundGradientKey}}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseDownBorderKey}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,4">
            <TextBox x:Name="SearchBox"
                     Padding="4,2"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged"
                     PreviewKeyDown="SearchBox_PreviewKeyDown"/>
            <TextBlock x:Name="PlaceholderText"
                       Text="Type to filter by file name (multiple words supported)"
                       Padding="6,3"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                       IsHitTestVisible="False"
                       Visibility="{Binding Text.Length, ElementName=SearchBox, Converter={local:PlaceholderVisibilityConverter}}"/>
        </Grid>

        <ListView x:Name="FileListView"
                  Grid.Row="1"
                  Margin="0,0,0,10"
                  SelectionMode="Extended"
                  BorderThickness="1"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.CanContentScroll="False"
                  HorizontalContentAlignment="Stretch"
                  UseLayoutRounding="True"
                  MouseDoubleClick="FileListView_MouseDoubleClick"
                  GridViewColumnHeader.Click="GridViewColumnHeader_Click"
                  SelectionChanged="FileListView_SelectionChanged"
                  ContextMenuOpening="FileListView_ContextMenuOpening"
                  KeyDown="FileListView_KeyDown">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="CtxCloseFiles" Header="Close File(s)" Click="CtxCloseFiles_Click"/>
                    <Separator/>
                    <MenuItem x:Name="CtxCopyFilename" Header="Copy Filename" Click="CtxCopyFilename_Click"/>
                    <MenuItem x:Name="CtxCopyFilePath" Header="Copy File Path" Click="CtxCopyFilePath_Click"/>
                    <MenuItem x:Name="CtxOpenContainingFolder" Header="Open Containing Folder" Click="CtxOpenContainingFolder_Click"/>
                    <Separator/>
                    <MenuItem x:Name="CtxSelectProjectFiles" Header="Select Files in Project" Click="CtxSelectProjectFiles_Click"/>
                    <MenuItem x:Name="CtxSelectMiscFiles" Header="Select Miscellaneous Files" Click="CtxSelectMiscFiles_Click"/>
                    <MenuItem Header="Select All" InputGestureText="Ctrl+A" Click="CtxSelectAll_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                    <GridViewColumn Header="File" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <Image Source="{Binding FullPath, Converter={local:FileIconConverter}}"
                                           Width="16" Height="16" Margin="0,0,4,0"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    <ContentPresenter>
                                        <ContentPresenter.Content>
                                            <MultiBinding Converter="{StaticResource HighlightConverter}">
                                                <Binding Path="FileName"/>
                                                <Binding Path="SearchWords"
                                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            </MultiBinding>
                                        </ContentPresenter.Content>
                                    </ContentPresenter>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Project" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Project}" Margin="0,1"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Path" Width="440">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullPath}" TextTrimming="CharacterEllipsis" Margin="0,1"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Modified" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Modified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Margin="0,1"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="OpenButton"
                    Content="Open"
                    Grid.Column="1"
                    Width="90"
                    Height="24"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OpenButton_Click"/>

            <Button Content="Cancel"
                    Grid.Column="2"
                    Width="90"
                    Height="24"
                    IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
