<Window x:Class="GoToRecentFile.View.GoToRecentFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:GoToRecentFile.View"
        mc:Ignorable="d"
        Title="Go To Recent File"
        Icon="/GoToRecentFile;component/Resources/Icon.png"
        MinWidth="760"
        MinHeight="420"
        Width="980"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontSize="12"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Window.Resources>
        <local:HighlightConverter x:Key="HighlightConverter" HighlightBrush="Yellow"/>

        <!-- Sort arrow header templates -->
        <DataTemplate x:Key="HeaderTemplateArrowUp">
            <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">
                <Path DockPanel.Dock="Right" Margin="4,0,0,0"
                      StrokeThickness="1" Fill="#FF606060"
                      Data="M 0,6 L 4,0 L 8,6 Z"
                      VerticalAlignment="Center"/>
                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </DockPanel>
        </DataTemplate>
        <DataTemplate x:Key="HeaderTemplateArrowDown">
            <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">
                <Path DockPanel.Dock="Right" Margin="4,0,0,0"
                      StrokeThickness="1" Fill="#FF606060"
                      Data="M 0,0 L 4,6 L 8,0 Z"
                      VerticalAlignment="Center"/>
                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </DockPanel>
        </DataTemplate>

        <!-- Left-align column headers with subtle gray hover -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="6,3,6,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border x:Name="HeaderBorder"
                                    BorderThickness="0,0,1,1"
                                    BorderBrush="#FFD0D0D0"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter x:Name="HeaderContent"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFF0F0F0" Offset="0"/>
                                            <GradientStop Color="#FFD8D8D8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="#FFB0B0B0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFD0D0D0" Offset="0"/>
                                            <GradientStop Color="#FFB8B8B8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="#FF909090"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView item style: light blue selection, outline on hover, close button with icon states -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="21"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <!-- Background layer for selection/hover fill -->
                            <Border x:Name="BgBd" Background="Transparent"/>
                            <!-- Content layer with cell borders for vertical lines -->
                            <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            <!-- Overlay border for hover/selection outline (does not affect layout) -->
                            <Border x:Name="OutlineBd"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    IsHitTestVisible="False"/>
                            <!-- Close button -->
                            <Button x:Name="CloseBtn"
                                    Visibility="Hidden"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Width="16" Height="16"
                                    Margin="0,0,4,0"
                                    Cursor="Hand"
                                    Click="CloseFileButton_Click"
                                    ToolTip="Remove from list"
                                    Tag="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid Width="16" Height="16" SnapsToDevicePixels="True">
                                            <Border x:Name="InactiveBd" Background="White"
                                                    BorderBrush="#FFE04040" BorderThickness="1"
                                                    CornerRadius="1">
                                                <Canvas Width="10" Height="10"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <Line X1="0" Y1="0" X2="10" Y2="10" Stroke="#FFE04040" StrokeThickness="1.5"/>
                                                    <Line X1="10" Y1="0" X2="0" Y2="10" Stroke="#FFE04040" StrokeThickness="1.5"/>
                                                </Canvas>
                                            </Border>
                                            <Border x:Name="ActiveBd" Background="#FFE04040"
                                                    BorderBrush="#FFE04040" BorderThickness="1"
                                                    CornerRadius="1" Visibility="Collapsed">
                                                <Canvas Width="10" Height="10"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <Line X1="0" Y1="0" X2="10" Y2="10" Stroke="White" StrokeThickness="1.5"/>
                                                    <Line X1="10" Y1="0" X2="0" Y2="10" Stroke="White" StrokeThickness="1.5"/>
                                                </Canvas>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="InactiveBd" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="ActiveBd" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="InactiveBd" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="ActiveBd" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="ActiveBd" Property="Background" Value="#FFC03030"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OutlineBd" Property="BorderBrush" Value="#FFB0B0B0"/>
                                <Setter TargetName="CloseBtn" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BgBd" Property="Background" Value="#FFD8EAFA"/>
                                <Setter TargetName="OutlineBd" Property="BorderBrush" Value="#FF7EB4EA"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="OutlineBd" Property="BorderBrush" Value="#FF7EB4EA"/>
                                <Setter TargetName="CloseBtn" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,4">
            <TextBox x:Name="SearchBox"
                     Padding="4,2"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged"
                     PreviewKeyDown="SearchBox_PreviewKeyDown"/>
            <TextBlock x:Name="PlaceholderText"
                       Text="Type to filter by file name (multiple words supported)"
                       Padding="6,3"
                       VerticalAlignment="Center"
                       Foreground="Gray"
                       IsHitTestVisible="False"
                       Visibility="{Binding Text.Length, ElementName=SearchBox, Converter={local:PlaceholderVisibilityConverter}}"/>
        </Grid>

        <ListView x:Name="FileListView"
                  Grid.Row="1"
                  Margin="0,0,0,10"
                  SelectionMode="Single"
                  BorderBrush="Gray"
                  BorderThickness="1"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  HorizontalContentAlignment="Stretch"
                  UseLayoutRounding="True"
                  MouseDoubleClick="FileListView_MouseDoubleClick"
                  GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                <ListView.View>
                    <GridView>
                    <GridViewColumn Header="File" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <Image Source="{Binding FullPath, Converter={local:FileIconConverter}}"
                                           Width="16" Height="16" Margin="0,0,4,0"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    <ContentPresenter>
                                        <ContentPresenter.Content>
                                            <MultiBinding Converter="{StaticResource HighlightConverter}">
                                                <Binding Path="FileName"/>
                                                <Binding Path="SearchWords"
                                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            </MultiBinding>
                                        </ContentPresenter.Content>
                                    </ContentPresenter>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Project" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Project}" Margin="0,1"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Path" Width="440">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullPath}" TextTrimming="CharacterEllipsis" Margin="0,1"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Modified" Width="140">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Modified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Margin="0,1"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Open"
                    Grid.Column="1"
                    Width="90"
                    Height="24"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OpenButton_Click"/>

            <Button Content="Cancel"
                    Grid.Column="2"
                    Width="90"
                    Height="24"
                    IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
